---
// src/components/Gallery.astro

// Here is your dynamic list of photos. 
// Rename your WhatsApp images to match these 'src' names and put them in public/images/
const photos = [
  { src: './src/assets/studio-desk.jpeg', alt: 'Sarajevo Studio Setup', span: 'col-span-2 row-span-2' },
  { src: './src/assets/vip-anwar.jpeg', alt: 'PM Anwar Ibrahim Coverage', span: 'col-span-1 row-span-1' },
  { src: './src/assets/asean-summit.jpeg', alt: 'ASEAN Summit Setup', span: 'col-span-1 row-span-2' },
  { src: './src/assets/japan-crew.jpeg', alt: 'Documentary Crew in Japan', span: 'col-span-1 row-span-1' },
  { src: './src/assets/director-monitor.jpeg', alt: 'Technical Directing', span: 'col-span-2 row-span-1' },
  { src: './src/assets/camera-rig.jpeg', alt: 'Heavy Camera Rig Setup', span: 'col-span-1 row-span-1' },
  { src: './src/assets/africa-doc.jpeg', alt: 'Documentary in Africa', span: 'col-span-1 row-span-1' },
  { src: './src/assets/vip-muhyiddin.jpeg', alt: 'Tan Sri Muhyiddin Coverage', span: 'col-span-2 row-span-1' },
];
---

<div class="gallery-wrapper">
  <div class="bento-grid">
    {photos.map((photo) => (
      <div class={`gallery-item gsap-gallery-item ${photo.span}`}>
        <img src={photo.src} alt={photo.alt} loading="lazy" />
        <div class="overlay">
          <span class="overlay-text">{photo.alt}</span>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .gallery-wrapper {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 0;
  }

  /* Modern Bento Grid */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 280px;
    gap: 16px;
  }

  /* Responsive Adjustments */
  @media (max-width: 900px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 220px;
    }
    .col-span-2 { grid-column: span 2; }
    .row-span-2 { grid-row: span 1; } /* Flatten tall images on mobile */
  }

  @media (max-width: 500px) {
    .bento-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 250px;
    }
    .col-span-1, .col-span-2, .row-span-1, .row-span-2 {
      grid-column: span 1;
      grid-row: span 1;
    }
  }

  /* Grid Item & Aesthetic Styling */
  .gallery-item {
    position: relative;
    border-radius: 16px; /* Smooth, modern corners */
    overflow: hidden;
    background-color: #1e293b; /* Fallback skeleton color */
    cursor: pointer;
  }

  .col-span-2 { grid-column: span 2; }
  .row-span-2 { grid-row: span 2; }

  /* Cinematic Image Effects */
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(30%) brightness(0.8);
    transition: transform 0.7s cubic-bezier(0.25, 1, 0.5, 1), filter 0.7s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.05); /* Smooth zoom */
    filter: grayscale(0%) brightness(1.1); /* Pop colors on hover */
  }

  /* Sleek Text Overlay */
  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 60%);
    opacity: 0;
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
    transition: opacity 0.4s ease;
  }

  .gallery-item:hover .overlay {
    opacity: 1;
  }

  .overlay-text {
    color: white;
    font-weight: 600;
    font-size: 1.1rem;
    transform: translateY(10px);
    transition: transform 0.4s ease;
  }

  .gallery-item:hover .overlay-text {
    transform: translateY(0);
  }
</style>