---
// src/components/Hero.astro
---
<div class="video-hero" id="hero">
    
    <video 
        class="bg-video" 
        autoplay 
        loop 
        muted 
        playsinline 
        disablePictureInPicture
        controlsList="nodownload noplaybackrate"
        oncontextmenu="return false;"
        poster="/images/hero-poster.webp"
    >
        <source src="/videos/hero-showreel.mp4" type="video/mp4" />
    </video>

    <div class="video-overlay"></div>

    <div class="hero-content">
        <h1 class="gsap-hero hero-title">
            FABAREEL <br/><span class="kreatif-text">KREATIF</span>
        </h1>
        <p class="gsap-hero hero-subtitle">
            A Bumiputera-owned strategic communication agency. Visual excellence from local summits to global frontiers.
        </p>
        <div class="gsap-hero">
            <a href="#work" class="primary-btn">
                Explore Our Work
            </a>
        </div>
    </div>
</div>

<style>
    .video-hero {
        position: relative;
        /* THE FIX: Changed to 100vh and removed the margin-top completely */
        height: 100vh !important; 
        margin-top: 0 !important; 
        
        width: 100vw !important;
        max-width: 100vw !important;
        padding: 0 !important;
        margin-left: calc(-50vw + 50%) !important; 

        display: flex;
        align-items: center;
        justify-content: center; 
        overflow: hidden;
        background-color: #050505; 
    }

    .bg-video {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover; 
        z-index: 0;
    }

    .video-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.65); 
        z-index: 1;
    }

    .hero-content {
        position: relative;
        z-index: 2; 
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 0 2rem;
        max-width: 900px;
        width: 100%;
        box-sizing: border-box;
    }

    .hero-title {
        font-size: clamp(3.5rem, 9vw, 6.5rem);
        margin-bottom: 0.5rem;
        line-height: 1.1;
        font-weight: 900;
        letter-spacing: 2px;
        color: white;
    }

    .kreatif-text {
        color: var(--text-muted);
        font-weight: 400;
    }

    .hero-subtitle {
        font-size: 1.25rem;
        max-width: 650px;
        margin-bottom: 2.5rem;
        color: #e5e7eb;
        line-height: 1.6;
    }

    .primary-btn {
        display: inline-block;
        padding: 1.1rem 2.8rem;
        background: white;
        color: black;
        text-decoration: none;
        border-radius: 4px;
        font-weight: 700;
        font-size: 1.1rem;
        transition: transform 0.3s ease, background 0.3s ease;
    }

    .primary-btn:hover {
        background: #e5e7eb;
        transform: translateY(-3px);
    }

    /* === MOBILE OPTIMIZATIONS === */
    @media (max-width: 768px) {
        .hero-content {
            padding: 0 1.5rem;
        }
        .hero-title {
            font-size: clamp(2.8rem, 12vw, 4rem); 
        }
        .hero-subtitle {
            font-size: 1.05rem; 
            margin-bottom: 2rem;
        }
        .primary-btn {
            padding: 1rem 2.5rem;
            font-size: 1rem;
        }
    }
</style>