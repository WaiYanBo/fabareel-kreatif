---
<section id="clients-preview" class="gsap-section" style="max-width: 1200px; text-align: center; margin-top: 6rem; padding: 0 2rem; margin-left: auto; margin-right: auto;">
    <span style="color: var(--text-muted); font-weight: 600; letter-spacing: 2px; text-transform: uppercase; font-size: 0.85rem;">Trusted By</span>
    <h2 style="font-size: 2.5rem; margin-top: 0.5rem; margin-bottom: 3rem;">Our Premier Partners</h2>
    <div class="client-grid-preview">
        <div class="client-logo-box">Air Asia</div>
        <div class="client-logo-box">RTM</div>
        <div class="client-logo-box">Universiti Malaya</div>
        <div class="client-logo-box">Tourism Johor</div>
    </div>
    <a href="/clients" class="outline-btn" style="margin-top: 3rem;">View All Clients &rarr;</a>
</section>

<style>
    .client-grid-preview {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
    }
    .client-logo-box {
        background: rgba(30, 41, 59, 0.4);
        border: 1px solid #334155;
        padding: 2rem 1rem;
        border-radius: 8px;
        color: var(--text-muted);
        font-weight: 600;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        transition: background 0.3s ease, color 0.3s ease;
    }
    .client-logo-box:hover {
        background: rgba(30, 41, 59, 0.8);
        color: white;
    }
    .outline-btn {
        display: inline-block;
        padding: 0.8rem 2rem;
        color: white;
        background: transparent;
        border: 1px solid white;
        border-radius: 4px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }
    .outline-btn:hover {
        background: white;
        color: black;
        transform: translateY(-2px);
    }
    @media (max-width: 768px) {
        .client-grid-preview {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>