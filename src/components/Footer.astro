---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
    <div class="footer-container">
        
        <div class="footer-col brand-col">
            <a href="/" class="brand-group">
                <span class="brand-text">FABAREEL<span class="accent">KREATIF</span></span>
            </a>
            <p class="brand-desc">
                A Bumiputera-owned strategic communication agency specializing in premium video and graphic production from conceptualization to polished post-production.
            </p>
        </div>

        <div class="footer-col">
            <h4>Quick Links</h4>
            <nav class="footer-nav">
                <a href="/about">About Us</a>
                <a href="/clients">Our Clients</a>
                <a href="/#work">Portfolio</a>
                <a href="/#contact">Contact</a>
            </nav>
        </div>

        <div class="footer-col">
            <h4>Our Services</h4>
            <nav class="footer-nav">
                <a href="/photography">VIP & Corporate Photography</a>
                <a href="/videography">Video Marketing</a>
                <a href="/videography">Documentaries</a>
                <a href="/videography">Broadcast Setup</a>
            </nav>
        </div>

        <div class="footer-col">
            <h4>Headquarters</h4>
            <address class="footer-contact">
                No 22A, Jalan 7/23E Taman Danau Kota<br/>
                Setapak 53000 Wilayah Persekutuan<br/>
                Kuala Lumpur, Malaysia
            </address>
            <div class="contact-links" style="margin-top: 1rem;">
                <a href="mailto:fabareelkreatif@gmail.com">fabareelkreatif@gmail.com</a>
                <a href="tel:+60192628404">+60 19-262 8404</a>
            </div>
        </div>

    </div>

    <div class="footer-bottom">
        <div class="footer-bottom-container">
            <p>&copy; {currentYear} Fabareel Kreatif Sdn. Bhd. (1399599-T). All Rights Reserved.</p>
            <div class="social-links">
                <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram">IG</a>
                <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook">FB</a>
                <a href="https://youtube.com" target="_blank" rel="noopener noreferrer" aria-label="YouTube">YT</a>
            </div>
        </div>
    </div>
</footer>

<style>
    .site-footer {
        background: rgba(10, 10, 10, 0.5); /* Let's the background orbs bleed through slightly */
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        padding-top: 4rem;
        position: relative;
        z-index: 10;
        margin-top: 4rem;
    }

    .footer-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1.5fr;
        gap: 3rem;
    }

    @media (max-width: 900px) {
        .footer-container {
            grid-template-columns: 1fr 1fr;
        }
    }

    @media (max-width: 600px) {
        .footer-container {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
    }

    /* Brand Column */
    .brand-group {
        text-decoration: none;
        display: inline-block;
        margin-bottom: 1rem;
    }

    .brand-text {
        font-size: 1.5rem;
        font-weight: 800;
        color: white;
        letter-spacing: 1px;
    }
    
    .brand-text .accent {
        color: var(--text-muted);
        font-weight: 400;
        margin-left: 4px;
    }

    .brand-desc {
        color: var(--text-muted);
        font-size: 0.95rem;
        line-height: 1.6;
        max-width: 350px;
        margin: 0;
    }

    /* Columns Setup */
    .footer-col h4 {
        color: white;
        font-size: 1.1rem;
        margin-bottom: 1.2rem;
        font-weight: 600;
    }

    .footer-nav {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
    }

    .footer-nav a, .contact-links a {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.95rem;
        transition: color 0.2s ease;
        display: block;
    }

    .footer-nav a:hover, .contact-links a:hover {
        color: white;
    }

    .footer-contact {
        color: var(--text-muted);
        font-size: 0.95rem;
        font-style: normal;
        line-height: 1.6;
    }

    .contact-links {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    /* Bottom Copyright Bar */
    .footer-bottom {
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        margin-top: 4rem;
        padding: 1.5rem 0;
    }

    .footer-bottom-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .footer-bottom-container p {
        color: var(--text-muted);
        font-size: 0.85rem;
        margin: 0;
    }

    .social-links {
        display: flex;
        gap: 1.5rem;
    }

    .social-links a {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 1px;
        transition: color 0.2s ease;
    }

    .social-links a:hover {
        color: white;
    }
</style>