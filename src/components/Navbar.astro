---
// src/components/Navbar.astro
---

<header class="site-header">
  <div class="nav-container">
    <a href="/" class="brand-group">
      <img src="/images/logo.webp" alt="Fabareel Kreatif Logo" class="nav-logo" onerror="this.style.display='none';" />
      <span class="brand-text">FABAREEL<span class="accent">KREATIF</span></span>
    </a>
  
    <nav class="nav-links">
      <a href="/about">About Us</a>
      
      <div class="mega-wrapper">
        <a href="/photography" class="mega-trigger">Photography</a>
        
        <div class="mega-menu">
          <div class="mega-content">
            
            <div class="mega-grid-text">
              <a href="/photography" class="mega-text-item">
                <span class="mega-main-text">Weddings</span>
                <span class="mega-arrow">&rarr;</span>
              </a>
              <a href="/photography" class="mega-text-item">
                <span class="mega-main-text">Corporate</span>
                <span class="mega-arrow">&rarr;</span>
              </a>
              <a href="/photography" class="mega-text-item">
                <span class="mega-main-text">Documentary</span>
                <span class="mega-arrow">&rarr;</span>
              </a>
              <a href="/photography" class="mega-text-item">
                <span class="mega-main-text">Broadcast</span>
                <span class="mega-arrow">&rarr;</span>
              </a>
            </div>

            <div class="mega-sidebar">
              <h4 class="sidebar-title">DISCOVER</h4>
              <a href="/photography">View All Categories</a>
              <a href="/photography">Cultural & Ceremonial</a>
              <a href="/photography">Commercial & Ads</a>
              <a href="/photography">Live Concerts</a>
              <a href="/photography">Studio Portraiture</a>
            </div>

          </div>
        </div>
      </div>
      
      <a href="/videography">Videography</a>
      <a href="/clients">Clients</a>
      <a href="/#work">Our Work</a>
    </nav>
  
    <div class="nav-actions">
      <a href="/#contact" class="cta-button">Let's Talk</a>
      
      <button class="mobile-toggle" aria-label="Toggle Menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
  
  <div class="mobile-menu">
    <a href="/about">About Us</a>
    <a href="/photography">Photography</a>
    <a href="/videography">Videography</a>
    <a href="/clients">Clients</a>
    <a href="/#work">Our Work</a>
    <a href="/#contact" class="mobile-cta">Let's Talk</a>
  </div>
</header>
  
<style>
  /* 1. Default State: Transparent */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  /* 2. THE FIX: Solid state applied when scrolled OR when the mouse hovers over the navbar */
  .site-header.nav-scrolled,
  .site-header:hover {
    background: rgba(10, 10, 10, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  /* 3. Hidden State */
  .site-header.nav-hidden {
    transform: translateY(-100%);
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem;
  }

  .brand-group {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }

  .nav-logo {
    height: 40px;
    width: auto;
    object-fit: contain;
    display: block;
    transition: transform 0.3s ease;
  }

  .brand-group:hover .nav-logo {
    transform: scale(1.05); 
  }

  .brand-text {
    font-size: 1.25rem;
    font-weight: 800;
    color: white;
    letter-spacing: 1px;
    line-height: 1; 
  }
  
  .brand-text .accent {
    color: var(--text-muted);
    font-weight: 400;
    margin-left: 4px;
  }

  .nav-links {
    display: flex;
    gap: 2rem; 
    align-items: center;
    height: 100%; 
  }

  .nav-links > a, .mega-trigger {
    color: #e5e7eb;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.3s ease;
    padding: 1.5rem 0; 
  }

  .nav-links > a:hover, .mega-trigger:hover {
    color: white;
  }

  .mega-wrapper {
    position: static; 
    height: 100%; 
    display: flex;
    align-items: center;
  }

  .mega-menu {
    position: absolute;
    top: 100%; 
    left: 0;
    width: 100vw;
    /* Matches the solid header perfectly so they blend together */
    background: rgba(10, 10, 10, 0.95); 
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.3s ease;
    pointer-events: none;
    box-shadow: 0 15px 40px rgba(0,0,0,0.6);
  }

  .mega-menu::before {
    content: '';
    position: absolute;
    top: -40px; 
    left: 0;
    width: 100%;
    height: 40px;
    background: transparent; 
  }

  .mega-wrapper:hover .mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  .mega-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
  }

  /* NEW: Typography-based Grid */
  .mega-grid-text {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .mega-text-item {
    text-decoration: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    transition: border-color 0.3s ease;
  }

  .mega-main-text {
    color: white;
    font-size: 1.5rem;
    font-weight: 700;
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .mega-arrow {
    color: var(--text-muted);
    font-size: 1.5rem;
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.3s ease;
  }

  .mega-text-item:hover {
    border-color: rgba(255, 255, 255, 0.2);
  }

  .mega-text-item:hover .mega-main-text {
    transform: translateX(10px);
    color: #e5e7eb;
  }

  .mega-text-item:hover .mega-arrow {
    opacity: 1;
    transform: translateX(0);
    color: white;
  }

  .mega-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-left: 1px solid #334155;
    padding-left: 3rem;
  }

  .sidebar-title {
    color: var(--text-muted);
    font-size: 0.8rem;
    letter-spacing: 2px;
    margin-bottom: 0.5rem;
  }

  .mega-sidebar a {
    color: #e5e7eb;
    text-decoration: none;
    font-size: 1rem;
    transition: color 0.2s ease;
  }

  .mega-sidebar a:hover {
    color: white;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .cta-button {
    background: white;
    color: black;
    padding: 0.6rem 1.5rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .cta-button:hover {
    background: #e5e7eb;
    transform: translateY(-2px);
  }

  .mobile-toggle {
    display: none;
    background: none;
    border: none;
    color: white;
    cursor: pointer;
    padding: 0.5rem;
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    background: #0a0a0a;
    padding: 1rem 2rem 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .mobile-menu a {
    color: white;
    text-decoration: none;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    font-size: 1.1rem;
  }

  .mobile-menu a.mobile-cta {
    color: black;
    background: white;
    text-align: center;
    border-radius: 4px;
    margin-top: 1rem;
    border: none;
  }

  @media (max-width: 950px) { 
    .nav-links { display: none; }
    .cta-button { display: none; }
    .mobile-toggle { display: block; }
    .mobile-menu.active { display: flex; }
    
    @media (max-width: 480px) {
      .brand-text { display: none; }
    }
  }
</style>
  
<script>
  const toggleBtn = document.querySelector('.mobile-toggle');
  const mobileMenu = document.querySelector('.mobile-menu');

  if (toggleBtn && mobileMenu) {
    toggleBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('active');
    });
  }

  const header = document.querySelector('.site-header');
  let lastScrollY = window.scrollY;

  window.addEventListener('scroll', () => {
    if (mobileMenu && mobileMenu.classList.contains('active')) return;

    const currentScrollY = window.scrollY;

    if (currentScrollY > 50) {
      header.classList.add('nav-scrolled');
    } else {
      header.classList.remove('nav-scrolled');
    }

    if (currentScrollY > lastScrollY && currentScrollY > 300) {
      header.classList.add('nav-hidden');
    } else {
      header.classList.remove('nav-hidden');
    }

    lastScrollY = currentScrollY;
  }, { passive: true }); 
</script>