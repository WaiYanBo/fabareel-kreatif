---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Footage Not Found | Fabareel Kreatif">
    <main class="error-wrapper">
        
        <div class="viewfinder-frame gsap-turn-on">
            
            <div class="cam-ui ui-top-left">
                <span class="rec-dot"></span> NO SIGNAL
            </div>
            <div class="cam-ui ui-top-right">
                <span class="blink-text">BAT: 0%</span>
            </div>
            
            <div class="cam-ui ui-bottom-left">
                FPS: <span class="highlight">404</span> | ISO: 3200 | SHUT: 1/50
            </div>
            <div class="cam-ui ui-bottom-right">
                TC: 00:04:04:00
            </div>

            <div class="bracket top-left"></div>
            <div class="bracket top-right"></div>
            <div class="bracket bottom-left"></div>
            <div class="bracket bottom-right"></div>

            <div class="center-target">
                <div class="target-line vertical"></div>
                <div class="target-line horizontal"></div>
            </div>

            <div class="error-content">
                <h1 class="error-code" data-text="404">404</h1>
                <h2 class="error-title">FOOTAGE NOT FOUND</h2>
                <p class="error-desc">
                    The scene you are looking for has been left on the cutting room floor, or the link was corrupted in post-production.
                </p>
                <a href="/" class="action-btn">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
                        <path d="M19 12H5M12 19l-7-7 7-7"/>
                    </svg>
                    Return to Base
                </a>
            </div>

        </div>

    </main>
</Layout>

<style>
    .error-wrapper {
        min-height: 100vh;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 6rem 2rem 2rem 2rem;
        position: relative;
        z-index: 10;
    }

    /* The Main Camera Monitor */
    .viewfinder-frame {
        position: relative;
        width: 100%;
        max-width: 1100px;
        aspect-ratio: 16 / 9;
        background: rgba(5, 5, 5, 0.6);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5), inset 0 0 100px rgba(0,0,0,0.8);
    }

    /* Camera UI Typography */
    .cam-ui {
        position: absolute;
        font-family: 'Courier New', Courier, monospace;
        font-size: 0.9rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.6);
        letter-spacing: 2px;
        z-index: 5;
    }

    .ui-top-left { top: 2rem; left: 2.5rem; display: flex; align-items: center; color: #ef4444; }
    .ui-top-right { top: 2rem; right: 2.5rem; }
    .ui-bottom-left { bottom: 2rem; left: 2.5rem; }
    .ui-bottom-right { bottom: 2rem; right: 2.5rem; }

    .highlight { color: #ef4444; font-weight: bold; }

    /* Blinking Recording Dot */
    .rec-dot {
        width: 12px;
        height: 12px;
        background-color: #ef4444;
        border-radius: 50%;
        margin-right: 10px;
        animation: blink 1s infinite;
        box-shadow: 0 0 10px #ef4444;
    }

    .blink-text {
        animation: blink 1.5s infinite;
        color: #ef4444;
    }

    @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
    }

    /* Cinematic Brackets */
    .bracket {
        position: absolute;
        width: 40px;
        height: 40px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        z-index: 4;
    }
    .top-left { top: 3rem; left: 3.5rem; border-right: none; border-bottom: none; }
    .top-right { top: 3rem; right: 3.5rem; border-left: none; border-bottom: none; }
    .bottom-left { bottom: 3rem; left: 3.5rem; border-right: none; border-top: none; }
    .bottom-right { bottom: 3rem; right: 3.5rem; border-left: none; border-top: none; }

    /* Center Crosshair */
    .center-target {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 60px;
        height: 60px;
        opacity: 0.15;
        pointer-events: none;
    }
    .target-line {
        position: absolute;
        background: white;
    }
    .vertical { width: 2px; height: 100%; left: 50%; transform: translateX(-50%); }
    .horizontal { width: 100%; height: 2px; top: 50%; transform: translateY(-50%); }

    /* Error Content & Glitch Effect */
    .error-content {
        text-align: center;
        z-index: 10;
        padding: 2rem;
        max-width: 600px;
    }

    .error-code {
        font-size: clamp(6rem, 15vw, 12rem);
        font-weight: 900;
        margin: 0;
        line-height: 1;
        position: relative;
        color: white;
        letter-spacing: 5px;
        /* Chromatic Aberration Effect */
        text-shadow: 
            -4px 0px 0px rgba(255, 0, 0, 0.7),
            4px 0px 0px rgba(0, 255, 255, 0.7);
        animation: slightGlitch 3s infinite;
    }

    @keyframes slightGlitch {
        0%, 100% { text-shadow: -4px 0px 0px rgba(255, 0, 0, 0.7), 4px 0px 0px rgba(0, 255, 255, 0.7); transform: skew(0deg); }
        5% { text-shadow: 4px 0px 0px rgba(255, 0, 0, 0.7), -4px 0px 0px rgba(0, 255, 255, 0.7); transform: skew(-2deg); }
        10% { text-shadow: -4px 0px 0px rgba(255, 0, 0, 0.7), 4px 0px 0px rgba(0, 255, 255, 0.7); transform: skew(0deg); }
    }

    .error-title {
        font-size: clamp(1.5rem, 4vw, 2.5rem);
        letter-spacing: 4px;
        margin-top: 1rem;
        margin-bottom: 1.5rem;
        color: #e5e7eb;
    }

    .error-desc {
        color: var(--text-muted);
        font-size: 1.1rem;
        line-height: 1.6;
        margin-bottom: 3rem;
    }

    /* Button */
    .action-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 1rem 2.5rem;
        background: transparent;
        color: white;
        text-decoration: none;
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 4px;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        backdrop-filter: blur(5px);
    }

    .action-btn:hover {
        background: white;
        color: black;
        border-color: white;
        transform: scale(1.05);
    }

    /* Mobile Responsiveness */
    @media (max-width: 900px) {
        .viewfinder-frame {
            aspect-ratio: 4 / 3; /* Taller on tablets */
        }
        .ui-bottom-left, .ui-bottom-right {
            font-size: 0.75rem;
        }
    }

    @media (max-width: 600px) {
        .viewfinder-frame {
            aspect-ratio: auto; /* Lets it naturally stretch on phones */
            min-height: 70vh;
        }
        .cam-ui { font-size: 0.7rem; }
        .ui-top-left { top: 1rem; left: 1rem; }
        .ui-top-right { top: 1rem; right: 1rem; }
        .ui-bottom-left { bottom: 1rem; left: 1rem; }
        .ui-bottom-right { display: none; /* Hide timecode on small screens to prevent clutter */ }
        .bracket { width: 20px; height: 20px; }
        .top-left { top: 2rem; left: 1.5rem; }
        .top-right { top: 2rem; right: 1.5rem; }
        .bottom-left { bottom: 2rem; left: 1.5rem; }
        .bottom-right { bottom: 2rem; right: 1.5rem; }
    }
</style>

<script>
    import { gsap } from "gsap";

    if (typeof window !== "undefined") {
        // "TV Turning On" effect when the page loads
        gsap.from(".gsap-turn-on", {
            scaleY: 0.01,
            scaleX: 0,
            opacity: 0,
            duration: 0.6,
            ease: "expo.inOut"
        });

        // Fades in the UI elements slowly after the monitor turns on
        gsap.from(".cam-ui, .bracket, .center-target", {
            opacity: 0,
            duration: 1,
            delay: 0.8,
            stagger: 0.1,
            ease: "power2.out"
        });
    }
</script>