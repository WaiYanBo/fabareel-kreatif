---
import Layout from '../layouts/Layout.astro';
import Gallery from '../components/Gallery.astro';
---

<Layout title="Fabareel Kreatif | Photography & Videography">
    <main>
        <section class="video-hero" id="hero">
            
            <video class="bg-video" autoplay loop muted playsinline poster="/images/hero-poster.webp">
                <source src="/videos/hero-showreel.mp4" type="video/mp4" />
            </video>

            <div class="video-overlay"></div>

            <div class="hero-content">
                <h1 class="gsap-hero" style="font-size: clamp(3rem, 10vw, 6rem); margin-bottom: 0.5rem; line-height: 1.1; font-weight: 900; letter-spacing: 2px;">
                    FABAREEL <br/><span style="color: var(--text-muted); font-weight: 400;">KREATIF</span>
                </h1>
                <p class="gsap-hero" style="font-size: 1.25rem; max-width: 650px; margin-bottom: 2.5rem; color: #e5e7eb; line-height: 1.6;">
                    A Bumiputera-owned strategic communication agency. Visual excellence from local summits to global frontiers.
                </p>
                <div class="gsap-hero">
                    <a href="#work" class="primary-btn">
                        Explore Our Work
                    </a>
                </div>
            </div>
        </section>

        <section id="about-preview" class="gsap-section" style="max-width: 900px; text-align: center; margin-top: 8rem;">
            <span style="color: var(--text-muted); font-weight: 600; letter-spacing: 2px; text-transform: uppercase; font-size: 0.85rem;">Who We Are</span>
            <h2 style="font-size: 2.5rem; margin-top: 0.5rem; margin-bottom: 1.5rem;">A Dynamic Bumiputera Production House</h2>
            
            <p style="font-size: 1.15rem; color: #d1d5db; line-height: 1.8; margin-bottom: 2rem;">
                Fabareel Kreatif Sdn. Bhd. is a Bumiputera-owned strategic communication agency specializing in premium video and graphic production. Driven by a dynamic team of young talents, we handle everything from initial conceptualization to voice recording and polished post-production.
            </p>

            <a href="/about" class="outline-btn">Discover Our Story &rarr;</a>
        </section>

        <section id="work" class="gsap-section" style="margin-top: 6rem;">
            <h2 style="font-size: 2.5rem; margin-bottom: 3rem; text-align: center;">Our Expertise</h2>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
                
                <div class="expertise-card">
                    <h3 style="font-size: 1.5rem; margin-bottom: 1rem;">Corporate & VIP</h3>
                    <p style="color: var(--text-muted);">High-end coverage for summits, government officials, and VIP engagements with utmost discretion.</p>
                </div>
                
                <div class="expertise-card">
                    <h3 style="font-size: 1.5rem; margin-bottom: 1rem;">Documentaries</h3>
                    <p style="color: var(--text-muted);">Global travelogues and compelling visual storytelling across borders, from Japan to Africa.</p>
                </div>
                
                <div class="expertise-card">
                    <h3 style="font-size: 1.5rem; margin-bottom: 1rem;">Broadcast Setup</h3>
                    <p style="color: var(--text-muted);">Professional studio setups, cinematic lighting, and technical multi-cam direction.</p>
                </div>

            </div>
        </section>

        <div class="gsap-section" style="margin-top: 4rem;">
            <h2 style="font-size: 2.5rem; margin-bottom: 1rem; text-align: center;">Behind The Lens</h2>
            <Gallery />
        </div>

        <section id="clients-preview" class="gsap-section" style="max-width: 1200px; text-align: center; margin-top: 6rem;">
            <span style="color: var(--text-muted); font-weight: 600; letter-spacing: 2px; text-transform: uppercase; font-size: 0.85rem;">Trusted By</span>
            <h2 style="font-size: 2.5rem; margin-top: 0.5rem; margin-bottom: 3rem;">Our Premier Partners</h2>

            <div class="client-grid-preview">
                <div class="client-logo-box">Air Asia</div>
                <div class="client-logo-box">RTM</div>
                <div class="client-logo-box">Universiti Malaya</div>
                <div class="client-logo-box">Tourism Johor</div>
            </div>

            <a href="/clients" class="outline-btn" style="margin-top: 3rem;">View All Clients &rarr;</a>
        </section>

        <section id="contact" class="gsap-section" style="max-width: 1000px; margin-top: 8rem; margin-bottom: 4rem;">
            <div style="text-align: center; margin-bottom: 3rem;">
                <h2 style="font-size: 2.5rem; margin-bottom: 1rem;">Let's Create Together</h2>
                <p style="color: var(--text-muted); font-size: 1.1rem;">Ready to elevate your visual storytelling? Drop us a message.</p>
            </div>

            <div class="contact-grid">
                <div class="contact-info">
                    <h3 style="font-size: 1.5rem; margin-bottom: 1.5rem;">Get In Touch</h3>
                    
                    <div class="info-item">
                        <strong style="display: block; color: white;">Email</strong>
                        <a href="mailto:fabareelkreatif@gmail.com" style="color: var(--text-muted); text-decoration: none;">fabareelkreatif@gmail.com</a>
                    </div>
                    
                    <div class="info-item" style="margin-top: 1.5rem;">
                        <strong style="display: block; color: white;">Phone / WhatsApp</strong>
                        <a href="tel:+60192628404" style="color: var(--text-muted); text-decoration: none;">+60 11-6362 3282</a>
                        <p style="color: var(--text-muted); margin: 0; font-size: 0.85rem;">Attn: Muhammad Jazli</p>
                    </div>

                    <div class="info-item" style="margin-top: 1.5rem;">
                        <strong style="display: block; color: white;">Headquarters</strong>
                        <p style="color: var(--text-muted); margin: 0; line-height: 1.8;">
                            Fabareel Kreatif Sdn. Bhd. (1399599-T)<br/>
                            No 22A, Jalan 7/23E Taman Danau Kota<br/>
                            Setapak 53000 Wilayah Persekutuan Kuala Lumpur
                        </p>
                    </div>
                </div>

                <form class="contact-form">
                    <div class="form-group">
                        <label for="name">Name</label>
                        <input type="text" id="name" name="name" placeholder="John Doe" required />
                    </div>

                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" placeholder="john@company.com" required />
                    </div>

                    <div class="form-group">
                        <label for="service">Service Needed</label>
                        <select id="service" name="service">
                            <option value="photography">Photography</option>
                            <option value="videography">Videography</option>
                            <option value="documentary">Documentary</option>
                            <option value="broadcast">Broadcast / Live Setup</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="message">Project Details</label>
                        <textarea id="message" name="message" rows="4" placeholder="Tell us about your project..." required></textarea>
                    </div>

                    <button type="submit" class="submit-btn">Send Message</button>
                </form>
            </div>
        </section>
    </main>

    <style>
        :root {
            --navbar-height: 80px; 
        }
    
        /* === NEW CENTERED VIDEO HERO STYLES === */
        .video-hero {
            position: relative;
            height: calc(100vh - var(--navbar-height));
            margin-top: var(--navbar-height);
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center; /* PERFECTLY CENTERED */
            overflow: hidden;
            background-color: #050505; 
        }
    
        .bg-video {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover; 
            z-index: 0;
        }

        .video-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.65); /* A single, smooth, elegant dark wash */
            z-index: 1;
        }
    
        .hero-content {
            position: relative;
            z-index: 2; 
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            padding: 0 2rem;
            max-width: 900px;
        }
    
        .primary-btn {
            display: inline-block;
            padding: 1.1rem 2.8rem;
            background: white;
            color: black;
            text-decoration: none;
            border-radius: 4px;
            font-weight: 700;
            font-size: 1.1rem;
            transition: transform 0.3s ease, background 0.3s ease;
        }
    
        .primary-btn:hover {
            background: #e5e7eb;
            transform: translateY(-3px);
        }
    
        /* === REST OF THE STYLES === */
        .expertise-card {
            background: rgba(30, 41, 59, 0.4);
            backdrop-filter: blur(8px);
            padding: 2.5rem;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: transform 0.3s ease, background 0.3s ease;
        }
    
        .expertise-card:hover {
            transform: translateY(-5px);
            background: rgba(30, 41, 59, 0.8);
        }
    
        .outline-btn {
            display: inline-block;
            padding: 0.8rem 2rem;
            color: white;
            background: transparent;
            border: 1px solid white;
            border-radius: 4px;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.3s ease;
        }
    
        .outline-btn:hover {
            background: white;
            color: black;
            transform: translateY(-2px);
        }
    
        .client-grid-preview {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.5rem;
        }
    
        @media (max-width: 768px) {
            :root {
                --navbar-height: 70px; 
            }
            .client-grid-preview {
                grid-template-columns: repeat(2, 1fr);
            }
            .hero-content {
                padding: 0 1.5rem;
            }
        }
    
        .client-logo-box {
            background: rgba(30, 41, 59, 0.4);
            border: 1px solid #334155;
            padding: 2rem 1rem;
            border-radius: 8px;
            color: var(--text-muted);
            font-weight: 600;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            transition: background 0.3s ease, color 0.3s ease;
        }
    
        .client-logo-box:hover {
            background: rgba(30, 41, 59, 0.8);
            color: white;
        }
    
        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 4rem;
            background: rgba(30, 41, 59, 0.4);
            backdrop-filter: blur(8px);
            padding: 3rem;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
    
        @media (max-width: 768px) {
            .contact-grid {
                grid-template-columns: 1fr;
                gap: 2rem;
                padding: 2rem;
            }
        }
    
        .contact-form {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }
    
        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }
    
        .form-group label {
            font-size: 0.9rem;
            color: #e5e7eb;
            font-weight: 500;
        }
    
        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 0.8rem 1rem;
            background: rgba(15, 23, 42, 0.8);
            border: 1px solid #334155;
            border-radius: 6px;
            color: white;
            font-family: inherit;
            font-size: 1rem;
            transition: border-color 0.3s ease;
            box-sizing: border-box;
        }
    
        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: #94a3b8;
        }
    
        .submit-btn {
            background: white;
            color: black;
            padding: 1rem;
            border: none;
            border-radius: 6px;
            font-weight: bold;
            font-size: 1rem;
            cursor: pointer;
            transition: background 0.3s ease, transform 0.2s ease;
            margin-top: 0.5rem;
        }
    
        .submit-btn:hover {
            background: #e5e7eb;
            transform: translateY(-2px);
        }
    </style>
</Layout>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    gsap.from(".gsap-hero", {
        y: 30,
        opacity: 0,
        duration: 1.2,
        stagger: 0.2,
        ease: "power3.out",
        delay: 0.2
    });

    gsap.utils.toArray('.gsap-section').forEach((section: any) => {
        gsap.from(section, {
            scrollTrigger: {
                trigger: section,
                start: "top 80%",
            },
            y: 50,
            opacity: 0,
            duration: 1,
            ease: "power2.out"
        });
    });
</script>