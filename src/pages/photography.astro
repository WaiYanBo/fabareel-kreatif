---

<Layout title="Photography Portfolio | Fabareel Kreatif">
    <main class="page-wrapper">
        
        <header class="page-header gsap-fade">
            <h1 class="page-title">OUR <span style="color: var(--text-muted); font-weight: 400;">LENS</span></h1>
            <p class="page-subtitle">A curated collection of visual excellence. From royal protocols to dynamic live broadcasts.</p>
        </header>

        <div class="filter-container gsap-fade">
            <button class="filter-btn active" data-filter="all">All Shots</button>
            <button class="filter-btn" data-filter="Corporate">Corporate & VIP</button>
            <button class="filter-btn" data-filter="Royal">Royal Protocol</button>
            <button class="filter-btn" data-filter="Government">Government</button>
            <button class="filter-btn" data-filter="Events">Events & Culture</button>
            <button class="filter-btn" data-filter="Production">Behind the Scenes</button>
        </div>

        <div class="masonry-grid gsap-fade">
            {photos.map((photo) => (
                <div class="masonry-item" data-category={photo.category}>
                    <img 
                        src={photo.src} 
                        alt={photo.description} 
                        loading="lazy" 
                        class="masonry-img"
                        onerror="this.onerror=null; this.src='https://placehold.co/600x400/1e293b/ffffff?text=Image+Missing';"
                    />
                    <div class="masonry-overlay">
                        <span class="overlay-category">{photo.category}</span>
                        <p class="overlay-desc">{photo.description}</p>
                    </div>
                </div>
            ))}
        </div>

    </main>

    <div id="image-modal" class="modal">
        <button class="modal-close" aria-label="Close Modal">&times;</button>
        <div class="modal-content">
            <img id="modal-image" src="" alt="Full Screen Preview" />
            <div id="modal-caption" class="modal-caption"></div>
        </div>
    </div>
</Layout>

<style>
    .page-wrapper {
        padding-top: 120px; 
        padding-bottom: 6rem;
        max-width: 1400px;
        margin: 0 auto;
        min-height: 100vh;
    }

    .page-header {
        text-align: center;
        margin-bottom: 3rem;
        padding: 0 2rem;
    }

    .page-title {
        font-size: clamp(3rem, 6vw, 4.5rem);
        font-weight: 900;
        letter-spacing: 2px;
        color: white;
        margin-bottom: 1rem;
    }

    .page-subtitle {
        color: #d1d5db;
        font-size: 1.15rem;
        max-width: 600px;
        margin: 0 auto;
        line-height: 1.6;
    }

    .filter-container {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 4rem;
        padding: 0 2rem;
    }

    .filter-btn {
        background: transparent;
        color: var(--text-muted);
        border: 1px solid #334155;
        padding: 0.6rem 1.5rem;
        border-radius: 30px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .filter-btn:hover, .filter-btn.active {
        background: white;
        color: black;
        border-color: white;
    }

    /* --- TRUE MASONRY WALL (NO CROPPING, WITH CLEAN GAPS) --- */
    .masonry-grid {
        column-count: 3; 
        column-gap: 1rem; 
        padding: 0 2rem;
    }

    .masonry-item {
        break-inside: avoid;
        margin-bottom: 1rem; 
        position: relative;
        overflow: hidden;
        border-radius: 6px; 
        cursor: zoom-in; /* Let users know they can click to expand */
        opacity: 1;
        transition: opacity 0.4s ease;
    }

    .masonry-item.hidden {
        display: none; 
    }

    .masonry-img {
        width: 100%;
        height: auto; 
        display: block; 
        transition: transform 0.5s ease, filter 0.4s ease;
    }

    .masonry-item:hover .masonry-img {
        transform: scale(1.05); 
        filter: brightness(0.4); 
    }

    .masonry-overlay {
        position: absolute;
        inset: 0; 
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.3) 50%, transparent 100%);
        padding: 1.5rem; 
        opacity: 0;
        transition: all 0.4s ease;
    }

    .masonry-item:hover .masonry-overlay {
        opacity: 1;
    }

    .overlay-category {
        color: #d1d5db;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-weight: 700;
        display: block;
        margin-bottom: 0.4rem;
    }

    .overlay-desc {
        color: white;
        font-size: 0.95rem;
        margin: 0;
        line-height: 1.4;
        font-weight: 500;
    }

    /* --- NEW: LIGHTBOX MODAL CSS --- */
    .modal {
        position: fixed;
        inset: 0;
        z-index: 9999; /* Ensures it sits over the navbar */
        background: rgba(5, 5, 5, 0.95);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
    }

    .modal.active {
        opacity: 1;
        pointer-events: auto;
    }

    .modal-content {
        position: relative;
        max-width: 90vw;
        max-height: 90vh;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    #modal-image {
        max-width: 100%;
        max-height: 80vh;
        object-fit: contain; /* Prevents stretching or cropping in modal */
        border-radius: 8px;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);
    }

    .modal-caption {
        color: white;
        margin-top: 1.5rem;
        font-size: 1.1rem;
        font-weight: 500;
        text-align: center;
        max-width: 800px;
    }

    .modal-close {
        position: absolute;
        top: 25px;
        right: 35px;
        color: white;
        font-size: 3rem;
        cursor: pointer;
        background: none;
        border: none;
        padding: 0;
        line-height: 1;
        transition: transform 0.2s ease, color 0.2s ease;
        z-index: 10000;
    }

    .modal-close:hover {
        transform: scale(1.1);
        color: #f97316; /* Brand orange hover effect */
    }

    /* --- RESPONSIVE ADJUSTMENTS --- */
    @media (max-width: 1024px) {
        .masonry-grid {
            column-count: 2;
        }
    }

    @media (max-width: 600px) {
        .masonry-grid {
            column-count: 1;
            padding: 0 1rem; 
        }
        .masonry-overlay {
            opacity: 1;
            background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, transparent 100%);
        }
        .modal-close {
            top: 15px;
            right: 20px;
            font-size: 2.5rem;
        }
    }
</style>

<script>
    if (typeof window !== "undefined") {
        const filterBtns = document.querySelectorAll('.filter-btn');
        const masonryItems = document.querySelectorAll('.masonry-item');
        
        // --- Lightbox Variables ---
        const modal = document.getElementById('image-modal');
        const modalImg = document.getElementById('modal-image') as HTMLImageElement;
        const modalCaption = document.getElementById('modal-caption');
        const closeBtn = document.querySelector('.modal-close');

        // 1. FILTERING LOGIC
        filterBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                filterBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');

                const filterValue = btn.getAttribute('data-filter');

                masonryItems.forEach((item) => {
                    const itemCategory = item.getAttribute('data-category');
                    if (filterValue === 'all' || itemCategory === filterValue) {
                        item.classList.remove('hidden');
                    } else {
                        item.classList.add('hidden');
                    }
                });
            });
        });

        // Handle URL Parameters for Auto-Filtering
        const urlParams = new URLSearchParams(window.location.search);
        const filterParam = urlParams.get('filter');
        if (filterParam) {
            const targetBtn = document.querySelector(`.filter-btn[data-filter="${filterParam}"]`) as HTMLElement;
            if (targetBtn) targetBtn.click(); 
        }

        // 2. LIGHTBOX (MODAL) LOGIC
        masonryItems.forEach((item) => {
            item.addEventListener('click', () => {
                const img = item.querySelector('.masonry-img') as HTMLImageElement;
                const desc = item.querySelector('.overlay-desc');
                const category = item.querySelector('.overlay-category');
                
                // Set the modal image and text
                if (img) modalImg.src = img.src;
                if (desc && category) {
                    modalCaption.innerHTML = `<span style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 2px; display: block; margin-bottom: 0.5rem;">${category.textContent}</span>${desc.textContent}`;
                }

                // Open modal and prevent body from scrolling
                modal.classList.add('active');
                document.body.style.overflow = 'hidden'; 
            });
        });

        // Close Modal Function
        const closeModal = () => {
            modal.classList.remove('active');
            document.body.style.overflow = ''; // Restore scrolling
            
            // Wait for fade out animation before removing image source
            setTimeout(() => {
                modalImg.src = '';
                modalCaption.innerHTML = '';
            }, 300);
        };

        // Close when clicking the X
        if(closeBtn) closeBtn.addEventListener('click', closeModal);
        
        // Close when clicking the dark background outside the image
        if(modal) {
            modal.addEventListener('click', (e) => {
                if (e.target === modal) closeModal();
            });
        }

        // Close when pressing the Escape key
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && modal.classList.contains('active')) {
                closeModal();
            }
        });
    }
</script>