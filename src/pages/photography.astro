---

<Layout title="Photography Portfolio | Fabareel Kreatif">
    <main class="page-wrapper">
        
        <header class="page-header gsap-fade">
            <h1 class="page-title">OUR <span style="color: var(--text-muted); font-weight: 400;">LENS</span></h1>
            <p class="page-subtitle">A curated collection of visual excellence. From royal protocols to dynamic live broadcasts.</p>
        </header>

        <div class="filter-container gsap-fade">
            <button class="filter-btn active" data-filter="all">All Shots</button>
            <button class="filter-btn" data-filter="Corporate">Corporate & VIP</button>
            <button class="filter-btn" data-filter="Royal">Royal Protocol</button>
            <button class="filter-btn" data-filter="Government">Government</button>
            <button class="filter-btn" data-filter="Events">Events & Culture</button>
            <button class="filter-btn" data-filter="Production">Behind the Scenes</button>
        </div>

        <div class="masonry-grid gsap-fade">
            {photos.map((photo) => (
                <div class="masonry-item" data-category={photo.category}>
                    <img 
                        src={photo.src} 
                        alt={photo.description} 
                        loading="lazy" 
                        width="600" 
                        height="400"
                        class="masonry-img"
                        onerror="this.onerror=null; this.src='https://placehold.co/600x400/1e293b/ffffff?text=Image+Missing';"
                    />
                    <div class="masonry-overlay">
                        <span class="overlay-category">{photo.category}</span>
                        <p class="overlay-desc">{photo.description}</p>
                    </div>
                </div>
            ))}
        </div>

    </main>
</Layout>

<style>
    .page-wrapper {
        padding-top: 120px; 
        padding-bottom: 6rem;
        max-width: 1400px;
        margin: 0 auto;
        min-height: 100vh;
    }

    .page-header {
        text-align: center;
        margin-bottom: 3rem;
        padding: 0 2rem;
    }

    .page-title {
        font-size: clamp(3rem, 6vw, 4.5rem);
        font-weight: 900;
        letter-spacing: 2px;
        color: white;
        margin-bottom: 1rem;
    }

    .page-subtitle {
        color: #d1d5db;
        font-size: 1.15rem;
        max-width: 600px;
        margin: 0 auto;
        line-height: 1.6;
    }

    .filter-container {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 4rem;
        padding: 0 2rem;
    }

    .filter-btn {
        background: transparent;
        color: var(--text-muted);
        border: 1px solid #334155;
        padding: 0.6rem 1.5rem;
        border-radius: 30px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .filter-btn:hover, .filter-btn.active {
        background: white;
        color: black;
        border-color: white;
    }

    .masonry-grid {
        column-count: 3;
        column-gap: 1.5rem;
        padding: 0 2rem;
    }

    .masonry-item {
        break-inside: avoid;
        margin-bottom: 1.5rem;
        position: relative;
        border-radius: 8px;
        overflow: hidden;
        cursor: pointer;
        opacity: 1;
        transform: scale(1);
        transition: opacity 0.4s ease, transform 0.4s ease;
    }

    .masonry-item.hidden {
        display: none; 
    }

    .masonry-img {
        width: 100%;
        height: auto;
        display: block;
        border-radius: 8px;
        transition: transform 0.5s ease;
    }

    .masonry-item:hover .masonry-img {
        transform: scale(1.05); 
    }

    .masonry-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 60%, transparent 100%);
        padding: 2rem 1.5rem 1.5rem 1.5rem;
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.3s ease;
    }

    .masonry-item:hover .masonry-overlay {
        opacity: 1;
        transform: translateY(0);
    }

    .overlay-category {
        color: var(--text-muted);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-weight: 700;
        display: block;
        margin-bottom: 0.5rem;
    }

    .overlay-desc {
        color: white;
        font-size: 1rem;
        margin: 0;
        line-height: 1.4;
        font-weight: 500;
    }

    @media (max-width: 1024px) {
        .masonry-grid {
            column-count: 2;
        }
    }

    @media (max-width: 600px) {
        .masonry-grid {
            column-count: 1;
        }
        .masonry-overlay {
            opacity: 1;
            transform: translateY(0);
            background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.2) 100%);
        }
    }
</style>
<script>
    // Filtering Logic for the Photography Grid
    if (typeof window !== "undefined") {
        const filterBtns = document.querySelectorAll('.filter-btn');
        const masonryItems = document.querySelectorAll('.masonry-item');

        filterBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                // 1. Remove active class from all buttons
                filterBtns.forEach(b => b.classList.remove('active'));
                
                // 2. Add active class to clicked button
                btn.classList.add('active');

                // 3. Get the category we want to filter by
                const filterValue = btn.getAttribute('data-filter');

                // 4. Show/Hide items based on category
                masonryItems.forEach((item) => {
                    const itemCategory = item.getAttribute('data-category');
                    
                    if (filterValue === 'all' || itemCategory === filterValue) {
                        item.classList.remove('hidden');
                    } else {
                        item.classList.add('hidden');
                    }
                });
            });
        });
        // NEW: Check for URL parameters to auto-filter on page load
        const urlParams = new URLSearchParams(window.location.search);
        const filterParam = urlParams.get('filter');
        
        if (filterParam) {
            // Find the button that matches the URL parameter
            const targetBtn = document.querySelector(`.filter-btn[data-filter="${filterParam}"]`);
            if (targetBtn) {
                // Programmatically click it to trigger your existing layout logic
                targetBtn.click(); 
            }
        }
    }
</script>

