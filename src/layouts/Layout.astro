---
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';

interface Props {
    title: string;
    description?: string;
    image?: string;
}

const { 
    title, 
    // Fallback description if a page doesn't specify one
    description = "A Bumiputera-owned strategic communication agency. Visual excellence from local summits to global frontiers.",
    // Fallback image (using your hero poster) for WhatsApp/LinkedIn previews
    image = "/images/hero-poster.webp" 
} = Astro.props;


// Make sure to update 'https://yourdomain.com' with the actual live domain later!
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://fabareelkreatif.com');
const ogImageURL = new URL(image, canonicalURL);
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/png" href="/favicon.png" />
        
        <title>{title}</title>
        <meta name="title" content={title} />
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />

        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImageURL} />

        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalURL} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={ogImageURL} />
    </head>
    <body>
        <div class="modern-bg-elements">
            
            <div class="bg-vignette"></div>
            
            <div class="bg-grid"></div>

            <div class="tech-line line-1"></div>
            <div class="tech-line line-2"></div>
            <div class="tech-line line-3"></div>
            
            <div class="glow-orb orange-orb"></div>
            <div class="glow-orb blue-orb"></div>
            <div class="glow-orb purple-orb"></div>
        </div>

        <Navbar />
        <slot /> 
		<Footer />
    </body>
</html>

<style is:global>
    :root {
        --bg-color: #0a0a0a;
        --text-main: #ffffff;
        --text-muted: #a3a3a3;
        --accent: #1e293b;
    }
    
    html {
        font-family: system-ui, sans-serif;
        background: var(--bg-color);
        color: var(--text-main);
    }
    
    body {
        margin: 0;
        padding: 0;
        overflow-x: hidden;
    }

    section {
        padding: 6rem 2rem;
        max-width: 1200px;
        margin: 0 auto;
        position: relative; /* Keeps content above the background */
        z-index: 10;
    }

    h1, h2, h3 { 
        margin: 0; 
        font-weight: 700;
    }

    /* =========================================
       MAXIMALIST BACKGROUND GRAPHICS
       ========================================= */
    .modern-bg-elements {
        position: fixed;
        inset: 0;
        width: 100vw;
        height: 100vh;
        z-index: -999; 
        overflow: hidden;
        pointer-events: none; 
        background-color: #030305; 
    }

    /* 1. Cinematic Vignette (Dark Edges) */
    .bg-vignette {
        position: absolute;
        inset: 0;
        box-shadow: inset 0 0 200px rgba(0,0,0,0.9);
        z-index: 5;
    }

    /* 2. Subtle Dot Grid */
    .bg-grid {
        position: absolute;
        inset: 0;
        background-image: radial-gradient(rgba(255, 255, 255, 0.15) 1px, transparent 1px);
        background-size: 30px 30px;
        opacity: 0.8;
        z-index: 1;
    }

    /* 3. Floating Tech Lasers */
    .tech-line {
        position: absolute;
        width: 200vw;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
        z-index: 2;
        left: -50vw;
    }
    .line-1 { top: 25%; animation: scanline 8s linear infinite; }
    .line-2 { top: 60%; animation: scanline 12s linear infinite reverse; }
    .line-3 { top: 85%; animation: scanline 15s linear infinite; }

    @keyframes scanline {
        0% { transform: translateY(-50px) translateX(-10%); opacity: 0; }
        50% { opacity: 1; }
        100% { transform: translateY(50px) translateX(10%); opacity: 0; }
    }

    /* 4. The Orbs */
    .glow-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(140px); 
        opacity: 0.25; /* Made them brighter! */
        animation: floatOrb 12s infinite alternate ease-in-out;
        z-index: 0;
        mix-blend-mode: screen; /* Makes the colors pop more when they overlap */
    }

    /* Fabareel Brand Orange */
    .orange-orb {
        width: 55vw;
        height: 55vw;
        background: #f97316; 
        top: -15%;
        left: -15%;
    }

    /* Cinematic Deep Blue */
    .blue-orb {
        width: 65vw;
        height: 65vw;
        background: #1e3a8a; 
        bottom: -20%;
        left: 20%;
        animation-delay: -4s; 
    }

    /* NEW: Neon Purple Orb */
    .purple-orb {
        width: 45vw;
        height: 45vw;
        background: #9333ea; 
        top: 20%;
        right: -10%;
        animation-delay: -8s; 
    }

    /* Faster, Wider Floating Animation */
    @keyframes floatOrb {
        0% { transform: translate(0, 0) scale(1); }
        50% { transform: translate(50px, -70px) scale(1.15); }
        100% { transform: translate(-60px, 40px) scale(0.85); }
    }
</style>
<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    // Only register and run if we are in the browser
    if (typeof window !== "undefined") {
        gsap.registerPlugin(ScrollTrigger);

        // 1. Global Hero/Fade Animations (Runs immediately)
        gsap.from(".gsap-hero, .gsap-fade", {
            y: 30,
            opacity: 0,
            duration: 1,
            stagger: 0.2,
            ease: "power3.out",
            delay: 0.1
        });

        // 2. Global Scroll Sections (Runs on scroll)
        // We use a slightly more generic class like .gsap-section or .client-category
        const scrollElements = gsap.utils.toArray('.gsap-section, .client-category');
        
        scrollElements.forEach((section: any) => {
            gsap.from(section, {
                scrollTrigger: {
                    trigger: section,
                    start: "top 80%",
                },
                y: 40,
                opacity: 0,
                duration: 0.8,
                ease: "power2.out"
            });
        });
    }
</script>